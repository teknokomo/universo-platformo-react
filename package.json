{
    "name": "universo-platformo-react",
    "version": "upr-0.63.0-alpha",
    "private": true,
    "packageManager": "pnpm@10.33.2",
    "homepage": "https://universo.pro",
    "workspaces": [
        "packages/*/base",
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build",
        "build:e2e": "node tools/testing/e2e/support/env/run-with-e2e-env.mjs pnpm build",
        "build-force": "pnpm clean && turbo run build --force",
        "dev": "turbo run dev --parallel",
        "check:catalog-versions": "node tools/check-catalog-versions.mjs",
        "docs:i18n:check": "node tools/docs/check-i18n-docs.mjs",
        "migration:status": "pnpm --filter @universo/migrations-platform exec node ./dist/cli.js status",
        "migration:plan": "pnpm --filter @universo/migrations-platform exec node ./dist/cli.js plan",
        "migration:diff": "pnpm --filter @universo/migrations-platform exec node ./dist/cli.js diff",
        "migration:export": "pnpm --filter @universo/migrations-platform exec node ./dist/cli.js export",
        "migration:validate": "pnpm --filter @universo/migrations-platform exec node ./dist/cli.js validate",
        "migration:lint": "pnpm --filter @universo/migrations-platform exec node ./dist/cli.js lint",
        "migration:doctor": "pnpm --filter @universo/migrations-platform exec node ./dist/cli.js doctor",
        "migration:sync": "pnpm --filter @universo/migrations-platform exec node ./dist/cli.js sync",
        "supabase:local:init": "node tools/local-supabase/init.mjs",
        "supabase:local:network": "node tools/local-supabase/network.mjs",
        "supabase:local:start": "node tools/local-supabase/supabase.mjs --action start --target dev --stack full && pnpm env:local-supabase",
        "supabase:local:start:minimal": "node tools/local-supabase/supabase.mjs --action start --target dev --stack minimal && pnpm env:local-supabase",
        "supabase:local:status": "node tools/local-supabase/supabase.mjs --action status --target dev",
        "supabase:local:stop": "node tools/local-supabase/supabase.mjs --action stop --target dev",
        "supabase:local:nuke": "node tools/local-supabase/supabase.mjs --action nuke --target dev",
        "supabase:e2e:start": "node tools/local-supabase/supabase.mjs --action start --target e2e --stack full",
        "supabase:e2e:start:minimal": "node tools/local-supabase/supabase.mjs --action start --target e2e --stack minimal",
        "supabase:e2e:status": "node tools/local-supabase/supabase.mjs --action status --target e2e",
        "supabase:e2e:stop": "node tools/local-supabase/supabase.mjs --action stop --target e2e",
        "supabase:e2e:nuke": "node tools/local-supabase/supabase.mjs --action nuke --target e2e",
        "env:local-supabase": "node tools/local-supabase/write-env.mjs --target dev",
        "env:e2e:local-supabase": "node tools/local-supabase/write-env.mjs --target e2e",
        "doctor:local-supabase": "node tools/local-supabase/doctor.mjs --target dev",
        "doctor:e2e:local-supabase": "node tools/local-supabase/doctor.mjs --target e2e",
        "start": "run-script-os",
        "start:windows": "cd packages/universo-core-backend/base/bin && run start",
        "start:default": "cd packages/universo-core-backend/base/bin && ./run start",
        "start:clean": "pnpm clean:all && pnpm install && pnpm build && pnpm start",
        "start:allclean": "pnpm clean:all && pnpm install && pnpm build && cross-env _FORCE_DATABASE_RESET=true pnpm start",
        "start:local-supabase": "pnpm supabase:local:start && pnpm doctor:local-supabase && cross-env UNIVERSO_ENV_FILE=.env.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.local-supabase pnpm start",
        "start:local-supabase:minimal": "pnpm supabase:local:start:minimal && pnpm doctor:local-supabase && cross-env UNIVERSO_ENV_FILE=.env.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.local-supabase pnpm start",
        "start:allclean:local-supabase": "pnpm supabase:local:start && pnpm doctor:local-supabase && pnpm clean:all && pnpm install && pnpm build && cross-env UNIVERSO_ENV_FILE=.env.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.local-supabase _FORCE_DATABASE_RESET=true pnpm start",
        "start:allclean:local-supabase:minimal": "pnpm supabase:local:start:minimal && pnpm doctor:local-supabase && pnpm clean:all && pnpm install && pnpm build && cross-env UNIVERSO_ENV_FILE=.env.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.local-supabase _FORCE_DATABASE_RESET=true pnpm start",
        "start-worker": "run-script-os",
        "start-worker:windows": "cd packages/universo-core-backend/base/bin && run worker",
        "start-worker:default": "cd packages/universo-core-backend/base/bin && ./run worker",
        "clean": "turbo run clean",
        "clean:all": "rimraf node_modules .turbo **/node_modules **/.turbo **/dist **/build",
        "build:clean": "pnpm clean:all && pnpm install && pnpm build",
        "nuke": "pnpm --filter \"./packages/**\" nuke && rimraf node_modules .turbo",
        "format": "prettier --write \"**/*.{ts,tsx,md}\"",
        "lint": "eslint \"**/*.{js,jsx,ts,tsx,json,md}\"",
        "lint-fix": "pnpm lint --fix",
        "test:vitest": "pnpm exec vitest run --workspace vitest.workspace.ts",
        "test:local-supabase:tools": "pnpm exec vitest run -c tools/local-supabase/vitest.config.mjs",
        "playwright:install": "pnpm exec playwright install chromium",
        "mcp:playwright": "pnpm dlx @playwright/mcp@0.0.52 --port 8931 --config tools/testing/e2e/playwright.mcp.config.json",
        "test:e2e:smoke": "node tools/testing/e2e/run-playwright-suite.mjs --grep @smoke",
        "build:e2e:local-supabase": "pnpm supabase:e2e:start:minimal && pnpm env:e2e:local-supabase && pnpm doctor:e2e:local-supabase && cross-env UNIVERSO_ENV_FILE=.env.e2e.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.e2e.local-supabase pnpm run build:e2e",
        "build:e2e:local-supabase:full": "pnpm supabase:e2e:start && pnpm env:e2e:local-supabase && pnpm doctor:e2e:local-supabase && cross-env UNIVERSO_ENV_FILE=.env.e2e.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.e2e.local-supabase pnpm run build:e2e",
        "test:e2e:smoke:local-supabase": "pnpm supabase:e2e:start:minimal && pnpm env:e2e:local-supabase && pnpm doctor:e2e:local-supabase && cross-env UNIVERSO_ENV_FILE=.env.e2e.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.e2e.local-supabase node tools/testing/e2e/run-playwright-suite.mjs --grep @smoke",
        "test:e2e:smoke:local-supabase:full": "pnpm supabase:e2e:start && pnpm env:e2e:local-supabase && pnpm doctor:e2e:local-supabase && cross-env UNIVERSO_ENV_FILE=.env.e2e.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.e2e.local-supabase node tools/testing/e2e/run-playwright-suite.mjs --grep @smoke",
        "test:e2e:flows:local-supabase": "pnpm supabase:e2e:start:minimal && pnpm env:e2e:local-supabase && pnpm doctor:e2e:local-supabase && cross-env UNIVERSO_ENV_FILE=.env.e2e.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.e2e.local-supabase node tools/testing/e2e/run-playwright-suite.mjs --grep @flow",
        "test:e2e:full:local-supabase": "pnpm supabase:e2e:start:minimal && pnpm env:e2e:local-supabase && pnpm doctor:e2e:local-supabase && cross-env UNIVERSO_ENV_FILE=.env.e2e.local-supabase UNIVERSO_FRONTEND_ENV_FILE=packages/universo-core-frontend/base/.env.e2e.local-supabase node tools/testing/e2e/run-playwright-suite.mjs --project chromium --project ru-light --project ru-dark",
        "test:e2e:flows": "node tools/testing/e2e/run-playwright-suite.mjs --grep @flow",
        "test:e2e:permissions": "node tools/testing/e2e/run-playwright-suite.mjs --grep @permission",
        "test:e2e:combined": "node tools/testing/e2e/run-playwright-suite.mjs --grep @combined",
        "test:e2e:visual": "node tools/testing/e2e/run-playwright-suite.mjs --grep @visual",
        "test:e2e:visual:update": "node tools/testing/e2e/run-playwright-suite.mjs --grep @visual --update-snapshots",
        "test:e2e:full": "node tools/testing/e2e/run-playwright-suite.mjs --project chromium --project ru-light --project ru-dark",
        "test:e2e:generators": "node tools/testing/e2e/run-playwright-suite.mjs --project generators",
        "test:e2e:restart-safe": "node tools/testing/e2e/restart-safe-check.mjs",
        "test:e2e:diagnostics": "node tools/testing/e2e/dialog-idle-diagnostics.mjs",
        "test:e2e:cleanup": "node tools/testing/e2e/support/backend/run-cleanup.mjs",
        "test:e2e:cleanup:manifest": "node tools/testing/e2e/support/backend/run-cleanup.mjs --manifest-only",
        "test:e2e:doctor": "node tools/testing/e2e/support/backend/run-e2e-doctor.mjs",
        "test:e2e:reset": "node tools/testing/e2e/support/backend/run-cleanup.mjs",
        "test:e2e:reset:dry": "node tools/testing/e2e/support/backend/run-cleanup.mjs --dry-run",
        "test:e2e:agent": "pnpm run build:e2e && pnpm run test:e2e:smoke && pnpm run test:e2e:flows",
        "check:react-bundle": "node tools/testing/check-react-require.mjs",
        "quick": "pretty-quick --staged",
        "postinstall": "husky install"
    },
    "lint-staged": {
        "*.{js,jsx,ts,tsx,json,md}": "eslint --fix"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.19.4",
        "@babel/preset-typescript": "7.18.6",
        "@happy-dom/jest-environment": "^20.8.8",
        "@playwright/test": "catalog:",
        "@reduxjs/toolkit": "^2.5.1",
        "@rolldown/binding-linux-x64-gnu": "1.0.0-beta.43",
        "@types/express": "^4.17.13",
        "@typescript-eslint/eslint-plugin": "^8.15.0",
        "@typescript-eslint/parser": "^8.15.0",
        "@vitest/coverage-v8": "^2.1.4",
        "cross-env": "^10.1.0",
        "eslint": "catalog:",
        "eslint-config-prettier": "^8.3.0",
        "eslint-config-react-app": "^7.0.1",
        "eslint-plugin-jsx-a11y": "^6.6.1",
        "eslint-plugin-markdown": "^3.0.0",
        "eslint-plugin-prettier": "^3.4.0",
        "eslint-plugin-react": "^7.26.1",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-unused-imports": "^4.3.0",
        "husky": "^8.0.1",
        "jest-canvas-mock": "^2.5.2",
        "kill-port": "^2.0.1",
        "lint-staged": "^13.0.3",
        "notistack": "catalog:",
        "pg": "8.11.1",
        "prettier": "^2.7.1",
        "pretty-quick": "^3.1.3",
        "react": "catalog:",
        "react-dom": "catalog:",
        "react-i18next": "catalog:",
        "rimraf": "^3.0.2",
        "run-script-os": "^1.1.6",
        "supabase": "^2.98.2",
        "tsdown": "catalog:",
        "turbo": "2.9.3",
        "typescript": "catalog:",
        "vitest": "catalog:"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "isolated-vm",
            "sqlite3",
            "supabase"
        ],
        "overrides": {
            "rolldown": "1.0.0-beta.43",
            "axios": "1.13.5",
            "@casl/ability": "6.7.5",
            "@remix-run/router": "1.23.2",
            "fast-xml-parser": "^5.3.8",
            "jsonwebtoken>jws": "3.2.3",
            "google-auth-library>jws": "4.0.1",
            "gtoken>jws": "4.0.1",
            "body-parser": "2.0.2",
            "braces": "3.0.3",
            "cross-spawn": "7.0.6",
            "glob-parent": "6.0.2",
            "glob>minimatch": "10.2.3",
            "@oclif/core>minimatch": "9.0.7",
            "json5": "2.2.3",
            "path-to-regexp": "0.1.12",
            "msw>path-to-regexp": "6.2.2",
            "semver": "7.7.1",
            "zod": "3.25.76",
            "react": "18.3.1",
            "react-dom": "18.3.1",
            "@types/react": "^18.0.0",
            "pg": "8.11.1",
            "@types/node": "20.12.12",
            "flatted": "^3.4.2"
        }
    },
    "engines": {
        "node": ">=22.6.0",
        "pnpm": ">=9"
    },
    "eslintIgnore": [
        "**/dist",
        "**/node_modules",
        "**/build",
        "**/package-lock.json"
    ],
    "prettier": {
        "printWidth": 140,
        "singleQuote": true,
        "jsxSingleQuote": true,
        "trailingComma": "none",
        "tabWidth": 4,
        "semi": false,
        "endOfLine": "auto"
    },
    "babel": {
        "presets": [
            "@babel/preset-typescript",
            [
                "@babel/preset-env",
                {
                    "targets": {
                        "node": "current"
                    }
                }
            ]
        ]
    },
    "dependencies": {
        "@casl/ability": "^6.7.5"
    }
}
