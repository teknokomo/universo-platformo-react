{
  "name": "@universo/store",
  "version": "0.1.0",
  "description": "Shared Redux store for Universo Platformo applications",
  "license": "Omsk Open License",
  "homepage": "https://universo.pro",
  "author": {
    "name": "Vladimir Levadnij and Teknokomo",
    "email": "info@universo.pro"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "typesVersions": {
    "*": {
      "*": [
        "dist/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsdown && tsc --emitDeclarationOnly --noEmit false",
    "dev": "tsdown --watch",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@casl/ability": "^6.7.5",
    "@casl/react": "^5.0.0",
    "@universo/types": "workspace:*",
    "redux": "^5.0.1"
  },
  "peerDependencies": {
    "react": "^18.3.1",
    "react-redux": "^9.1.0"
  },
  "devDependencies": {
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
