{
    "compilerOptions": {
        "target": "ES2017",
        "module": "Node16",
        "lib": ["ES2020"],
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": ".",
        "ignoreDeprecations": "5.0",
        "paths": {
            "@universo/admin-backend": ["../admin-backend/dist/index.d.ts"],
            "@universo/migrations-core": ["../universo-migrations-core/dist/index.d.ts"],
            "@universo/schema-ddl": ["../schema-ddl/dist/index.d.ts"],
            "@universo/modules-engine": ["../modules-engine/dist/index.d.ts", "../modules-engine/src/index.ts"]
        },
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "moduleResolution": "node16",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": ["node"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "src/tests/**/*"]
}
