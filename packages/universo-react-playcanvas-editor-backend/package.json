{
    "name": "@universo-react/playcanvas-editor-backend",
    "version": "0.1.0",
    "description": "Protocol backend boundary for Universo PlayCanvas Editor compatibility",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "scripts": {
        "clean": "rimraf dist",
        "build": "tsdown",
        "lint": "eslint --ext .ts src/",
        "test": "vitest run --config vitest.config.ts"
    },
    "license": "Omsk Open License",
    "dependencies": {
        "@universo-react/types": "workspace:*",
        "express": "^4.18.2",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "catalog:",
        "eslint": "catalog:",
        "rimraf": "^5.0.5",
        "tsdown": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
