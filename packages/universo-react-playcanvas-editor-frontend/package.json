{
    "name": "@universo-react/playcanvas-editor-frontend",
    "version": "0.1.0",
    "description": "Universo frontend artifact boundary for the PlayCanvas Editor",
    "main": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": "./src/index.ts",
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "private": true,
    "scripts": {
        "clean": "rimraf dist build .tmp coverage",
        "editor:build": "node scripts/build-editor.mjs",
        "editor:serve": "node scripts/serve-editor.mjs",
        "editor:smoke": "node scripts/smoke-editor-artifact.mjs",
        "editor:browser-smoke": "node scripts/browser-smoke-editor.mjs",
        "test": "vitest run --config vitest.config.ts"
    },
    "license": "Omsk Open License",
    "dependencies": {
        "@playcanvas/attribute-parser": "^1.10.1",
        "zod": "catalog:"
    },
    "devDependencies": {
        "@jsquash/avif": "1.3.0",
        "@jsquash/jpeg": "1.6.0",
        "@jsquash/png": "2.2.0",
        "@jsquash/webp": "1.5.0",
        "@playcanvas/observer": "1.7.1",
        "@playcanvas/pcui": "6.1.4",
        "@playcanvas/pcui-graph": "5.2.5",
        "@playwright/test": "catalog:",
        "@rollup/plugin-commonjs": "28.0.9",
        "@rollup/plugin-node-resolve": "15.3.1",
        "@rollup/plugin-swc": "0.4.0",
        "@sentry/browser": "^10.48.0",
        "@sentry/core": "^10.48.0",
        "@swc/core": "1.15.18",
        "@types/node": "catalog:",
        "@types/sharedb": "catalog:",
        "autoprefixer": "10.4.27",
        "dexie": "4.3.0",
        "esbuild": "0.27.4",
        "esbuild-plugin-polyfill-node": "0.3.0",
        "filenamify": "6.0.0",
        "highlight.js": "11.11.1",
        "markdown-it": "14.1.1",
        "monaco-editor": "0.47.0",
        "monaco-themes": "0.4.8",
        "ot-text": "github:playcanvas/ot-text#b3d5f9610f3a78a7782bbc3b466e1b88355d59e7",
        "playcanvas": "2.19.5",
        "pngjs": "5.0.0",
        "postcss": "8.5.12",
