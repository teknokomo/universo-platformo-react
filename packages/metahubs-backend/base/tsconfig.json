{
    "compilerOptions": {
        "target": "ES2017",
        "module": "Node16",
        "lib": ["ES2020"],
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": ".",
        "ignoreDeprecations": "5.0",
        "paths": {
            "@universo/admin-backend": ["../../admin-backend/base/dist/index.d.ts"],
            "@universo/applications-backend": ["../../applications-backend/base/dist/index.d.ts"],
            "@universo/migrations-catalog": ["../../universo-migrations-catalog/base/dist/index.d.ts"],
            "@universo/schema-ddl": ["../../schema-ddl/base/dist/index.d.ts"],
            "@universo/scripting-engine": [
                "../../scripting-engine/base/dist/index.d.ts",
                "../../scripting-engine/base/src/index.ts"
            ]
        },
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "moduleResolution": "node16",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "types": ["node"]
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "src/tests/**/*"]
}
