############################################################################################################
############################################################################################################
########################################### UNIVERSO PLATFORMO #############################################
############################################################################################################
############################################################################################################

PORT=3000
# HOST=0.0.0.0
# UNIVERSO_PATH=/your_platform_path


############################################################################################################
############################################## ADMIN PANEL #################################################
############################################################################################################

# ══════════════════════════════════════════════════════════════════════════════════
# THREE-TIER PRIVILEGE SYSTEM
# ══════════════════════════════════════════════════════════════════════════════════
# The admin system has three independent privilege levels that can be controlled separately:
#
# 1. ADMIN_PANEL_ENABLED - Controls UI/API access to admin panel (/admin/*)
#    - true: Admin menu visible, admin API endpoints work
#    - false: Admin menu hidden, admin API returns 403
#
# 2. GLOBAL_ROLES_ENABLED - Controls global editor/moderator roles
#    - true: Users with global roles can access platform-wide resources (within their permissions)
#    - false: Global roles exist but cannot access cross-user resources
#    - Note: This does NOT bypass RLS - users still see only permitted data
#
# 3. SUPERUSER_ENABLED - Controls superuser RLS bypass (HIGHEST privilege)
#    - true: Users with is_superuser=true can bypass ALL RLS policies and see ALL data
#    - false: Superuser role exists but RLS applies normally (no bypass, security-first)
#    - Warning: This is ROOT access - enable only when absolutely necessary
#
# ══════════════════════════════════════════════════════════════════════════════════
# COMMON SCENARIOS:
# ══════════════════════════════════════════════════════════════════════════════════
#
# Production (maximum security):
#   ADMIN_PANEL_ENABLED=true
#   GLOBAL_ROLES_ENABLED=true
#   SUPERUSER_ENABLED=false  ← Superuser disabled for security
#
# Development (full access):
#   ADMIN_PANEL_ENABLED=true
#   GLOBAL_ROLES_ENABLED=true
#   SUPERUSER_ENABLED=true   ← Superuser enabled for debugging
#
# Public instance (admin completely disabled):
#   ADMIN_PANEL_ENABLED=false
#   GLOBAL_ROLES_ENABLED=false
#   SUPERUSER_ENABLED=false
#
# Maintenance mode (only superuser can work):
#   ADMIN_PANEL_ENABLED=true
#   GLOBAL_ROLES_ENABLED=false  ← Regular admins blocked
#   SUPERUSER_ENABLED=true      ← Only root access works
#
# ══════════════════════════════════════════════════════════════════════════════════

# ADMIN_PANEL_ENABLED: Controls UI visibility and API access to the admin panel (/admin/*)
# Default: true
# ADMIN_PANEL_ENABLED=true

# GLOBAL_ROLES_ENABLED: Controls global editor/moderator roles (platform-wide permissions)
# Default: true
# GLOBAL_ROLES_ENABLED=true

# SUPERUSER_ENABLED: Controls superuser RLS bypass (see all data, root access)
# Default: true (set to false in production for security)
# SUPERUSER_ENABLED=true


############################################################################################################
##################################### MIGRATION CATALOG ###################################################
############################################################################################################

# UPL_GLOBAL_MIGRATION_CATALOG_ENABLED: Enables the full upl_migrations catalog/definition registry workflow.
# Default: false
# false: keep platform migration kernel only and skip catalog definition sync/export flows
# true: enable full catalog lifecycle, runtime global mirroring, doctor/export/import/sync catalog features
# UPL_GLOBAL_MIGRATION_CATALOG_ENABLED=false


############################################################################################################
########################################### DATABASE #######################################################
############################################################################################################

# DATABASE_PORT=5432
# DATABASE_HOST=""
# DATABASE_NAME=universo
# DATABASE_USER=root
# DATABASE_PASSWORD=mypassword
# DATABASE_SSL=true
# DATABASE_SSL_KEY_BASE64=<Self signed certificate in BASE64>

# ══════════════════════════════════════════════════════════════════════════════════
# DATABASE CONNECTION POOLING (Knex)
# ══════════════════════════════════════════════════════════════════════════════════
# Pool max should stay at or below the Supabase connection budget.
#
# Tier-scaling guide (Supabase):
#   Tier      | Pool Size | Recommended Knex pool max
#   ----------+-----------+---------------------------
#   Nano      |     15    |  5
#   Micro     |     15    |  8
#   Small     |     15    | 10
#   Medium    |     50    | 20
#   Large+    |    100    | 40
# ══════════════════════════════════════════════════════════════════════════════════
# Safe default for the current Supabase Nano profile used in this repo.
# Increase only if your Supabase tier allows a larger Knex pool budget.
DATABASE_POOL_MAX=5
# DATABASE_KNEX_ACQUIRE_TIMEOUT_MS=10000
# DATABASE_KNEX_IDLE_TIMEOUT_MS=15000
# DATABASE_KNEX_CREATE_TIMEOUT_MS=10000
# DATABASE_KNEX_POOL_DEBUG=false
# DATABASE_SHUTDOWN_GRACE_MS=15000
# ALLOW_TRANSACTION_POOLER=false


############################################################################################################
########################################### SUPABASE #######################################################
############################################################################################################

# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SERVICE_ROLE_KEY=
# SUPABASE_JWT_SECRET=


############################################################################################################
########################################## AUTHENTICATION ##################################################
############################################################################################################

# AUTH_REGISTRATION_ENABLED: Allow new user registration
# Default: true (enabled unless explicitly set to 'false')
# AUTH_REGISTRATION_ENABLED=true

# AUTH_LOGIN_ENABLED: Allow user login
# Default: true (enabled unless explicitly set to 'false')
# AUTH_LOGIN_ENABLED=true

# AUTH_EMAIL_CONFIRMATION_REQUIRED: Require email confirmation before granting access
# Default: true (required unless explicitly set to 'false')
# AUTH_EMAIL_CONFIRMATION_REQUIRED=true

# AUTO_ROLE_AFTER_ONBOARDING: Automatically grant the global `user` role after onboarding completion.
# Default: true (set to false to keep users on `/start` until an admin assigns `user` manually)
# AUTO_ROLE_AFTER_ONBOARDING=true

# BOOTSTRAP_SUPERUSER_ENABLED: Automatically create or confirm the startup superuser after migrations complete.
# Default: true
BOOTSTRAP_SUPERUSER_ENABLED=true

# BOOTSTRAP_SUPERUSER_EMAIL: Demo bootstrap superuser email for local/dev installs.
# Change this before any real deployment.
BOOTSTRAP_SUPERUSER_EMAIL=demo-admin@example.com

# BOOTSTRAP_SUPERUSER_PASSWORD: Demo bootstrap superuser password for local/dev installs.
# Change this before any real deployment.
BOOTSTRAP_SUPERUSER_PASSWORD=ChangeMe_123456!

# AUTH_RLS_DEBUG: Enable verbose RLS context debug logging (auth-backend)
# Default: false
# AUTH_RLS_DEBUG=false


############################################################################################################
############################################ LEGAL DOCUMENTS ###############################################
############################################################################################################

# Version tracking for Terms of Service and Privacy Policy
# Increment these when legal documents are updated to track user consent versions
# LEGAL_TERMS_VERSION=1.0.0
# LEGAL_PRIVACY_VERSION=1.0.0


############################################################################################################
############################################ SESSION #######################################################
############################################################################################################

# Session secret for secure cookie signing (required for authentication)
# SESSION_SECRET=my-secret-key

# SESSION_COOKIE_NAME: Cookie name for the session
# Default: up.session
# SESSION_COOKIE_NAME=up.session

# SESSION_COOKIE_MAXAGE: Cookie max age in milliseconds
# Default: 604800000 (7 days)
# SESSION_COOKIE_MAXAGE=604800000

# SESSION_COOKIE_SAMESITE: SameSite cookie attribute (lax | strict | none)
# Default: lax
# SESSION_COOKIE_SAMESITE=lax

# SESSION_COOKIE_SECURE: Set cookie secure flag (true only over HTTPS)
# Default: false (auto-true in production or when SameSite=none)
# SESSION_COOKIE_SECURE=false

# SESSION_COOKIE_PARTITIONED: Enable partitioned (CHIPS) cookies for cross-site embeds
# Default: false
# SESSION_COOKIE_PARTITIONED=false


############################################################################################################
############################################ CAPTCHA #######################################################
############################################################################################################

# Yandex SmartCaptcha integration (fail-closed: captcha disabled if keys missing)
# SMARTCAPTCHA_SERVER_KEY=<server-key-from-yandex-cloud>
# SMARTCAPTCHA_SITE_KEY=<site-key-from-yandex-cloud>
# SMARTCAPTCHA_TEST_MODE=false

# Per-feature captcha toggles (each requires SMARTCAPTCHA_SERVER_KEY + SMARTCAPTCHA_SITE_KEY)
# SMARTCAPTCHA_REGISTRATION_ENABLED=false
# SMARTCAPTCHA_LOGIN_ENABLED=false
# SMARTCAPTCHA_PUBLICATION_ENABLED=false


############################################################################################################
############################################## LOGGING #####################################################
############################################################################################################

# LOG_PATH=/your_log_path/.universo-platformo/logs
# LOG_LEVEL=info (error | warn | info | verbose | debug)


############################################################################################################
############################################## STORAGE #####################################################
############################################################################################################

# STORAGE_TYPE=local (local | s3)
# S3_STORAGE_BUCKET_NAME=universo-platformo
# S3_STORAGE_ACCESS_KEY_ID=<your-access-key>
# S3_STORAGE_SECRET_ACCESS_KEY=<your-secret-key>
# S3_STORAGE_REGION=us-west-2
# S3_ENDPOINT_URL=<custom-s3-endpoint-url>
# S3_FORCE_PATH_STYLE=false
# GOOGLE_CLOUD_STORAGE_CREDENTIAL=/the/keyfilename/path
# GOOGLE_CLOUD_STORAGE_PROJ_ID=<your-gcp-project-id>


############################################################################################################
############################################## SETTINGS ####################################################
############################################################################################################

# NUMBER_OF_PROXIES= 1
# CORS_ORIGINS=*
# IFRAME_ORIGINS=*

# FILE_SIZE_LIMIT=50mb


