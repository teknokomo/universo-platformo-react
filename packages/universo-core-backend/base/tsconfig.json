{
    "compilerOptions": {
        "lib": ["es2021"],
        "target": "es2021" /* Set the JavaScript language version for emitted JavaScript and include compatible library declarations. */,
        "experimentalDecorators": true /* Enable experimental support for TC39 stage 2 draft decorators. */,
        "emitDecoratorMetadata": true /* Emit design-type metadata for decorated declarations in source files. */,
        "module": "CommonJS" /* Specify what module code is generated. */,
        "outDir": "dist",
        "baseUrl": ".",
        "paths": {
            "@universo/database": ["../../universo-database/base/dist/index.d.ts", "../../universo-database/base/src/index.ts"],
            "@universo/applications-backend": ["../../applications-backend/base/dist/index.d.ts"],
            "@universo/metahubs-backend": ["../../metahubs-backend/base/dist/index.d.ts"],
            "@universo/migrations-core": [
                "../../universo-migrations-core/base/dist/index.d.ts",
                "../../universo-migrations-core/base/src/index.ts"
            ],
            "@universo/migrations-catalog": [
                "../../universo-migrations-catalog/base/dist/index.d.ts",
                "../../universo-migrations-catalog/base/src/index.ts"
            ],
            "@universo/migrations-platform": [
                "../../universo-migrations-platform/base/dist/index.d.ts",
                "../../universo-migrations-platform/base/src/index.ts"
            ],
            "@universo/schema-ddl": ["../../schema-ddl/base/dist/index.d.ts", "../../schema-ddl/base/src/index.ts"],
            "@universo/types": ["../../universo-types/base/dist/index.d.ts"]
        },
        "moduleResolution": "node",
        "esModuleInterop": true /* Emit additional JavaScript to ease support for importing CommonJS modules. This enables `allowSyntheticDefaultImports` for type compatibility. */,
        "forceConsistentCasingInFileNames": true /* Ensure that casing is correct in imports. */,
        "strict": true /* Enable all strict type-checking options. */,
        "skipLibCheck": true /* Skip type checking all .d.ts files. */,
        "sourceMap": true,
        "strictPropertyInitialization": false,
        "declaration": false,
        "types": ["node"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules", "**/*.test.ts"]
}
