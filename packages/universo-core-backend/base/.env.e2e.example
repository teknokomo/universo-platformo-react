PORT=3100
# HOST=127.0.0.1

# Use the dedicated UP-test Supabase project for agent-driven browser testing.
SUPABASE_URL=https://your-up-test-project.supabase.co
# Preferred key name for modern Supabase projects. The auth runtime reads this first.
SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_your_public_key
# Legacy variable name still supported for older setups.
# You can keep a legacy anon key here or duplicate the same publishable key value.
SUPABASE_ANON_KEY=sb_publishable_your_public_key_or_legacy_anon_key
SERVICE_ROLE_KEY=your_server_only_service_role_key
# Legacy projects that still issue HS256 session JWTs need SUPABASE_JWT_SECRET.
# Modern Supabase projects usually use asymmetric JWTs and can verify via JWKS derived from SUPABASE_URL.
# SUPABASE_JWT_SECRET=your_legacy_supabase_jwt_secret
# Optional JWKS overrides when you need explicit values instead of SUPABASE_URL-derived defaults:
# SUPABASE_JWKS_URL=https://your-up-test-project.supabase.co/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_ISSUER=https://your-up-test-project.supabase.co/auth/v1
# SUPABASE_JWT_AUDIENCE=authenticated

# Required database runtime for pnpm start / Playwright e2e runs.
# Do not use the transaction pooler (:6543) in this project.
# Start with direct connection if your machine can reach it over IPv6.
# If direct connection fails locally, use the session pooler (:5432) instead.
DATABASE_PORT=5432
DATABASE_HOST=your-project.pooler.supabase.com
DATABASE_NAME=postgres
DATABASE_USER=postgres.your_project_ref
DATABASE_PASSWORD=your_database_password

# Optional but recommended stability/settings for local e2e runs.
DATABASE_POOL_MAX=5
DATABASE_SSL=true
SESSION_SECRET=replace_with_a_long_random_value
LOG_LEVEL=info
STORAGE_TYPE=local

BOOTSTRAP_SUPERUSER_ENABLED=true
BOOTSTRAP_SUPERUSER_EMAIL=demo-admin@example.com
BOOTSTRAP_SUPERUSER_PASSWORD=ChangeMe_123456!
AUTH_LOGIN_RATE_LIMIT_WINDOW_MS=60000
AUTH_LOGIN_RATE_LIMIT_MAX=200

# E2E bootstrap and cleanup
E2E_TEST_USER_PASSWORD=ChangeMe_E2E-123456!
E2E_TEST_USER_ROLE_CODENAMES=User
E2E_TEST_USER_EMAIL_DOMAIN=example.test
# Default hosted-Supabase contract: reset the entire project-owned state before and after suites.
# Set to off only for manual debugging against an already running server.
E2E_FULL_RESET_MODE=strict
