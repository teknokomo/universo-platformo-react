{
    "name": "@universo/core-backend",
    "version": "0.1.0",
    "description": "Universo Platformo React Server",
    "license": "Omsk Open License",
    "homepage": "https://universo.pro",
    "author": {
        "name": "Vladimir Levadnij and Teknokomo",
        "email": "info@universo.pro"
    },
    "main": "dist/index",
    "types": "dist/index.d.ts",
    "bin": {
        "universo": "./bin/run"
    },
    "files": [
        "bin",
        "dist",
        "npm-shrinkwrap.json",
        "oclif.manifest.json"
    ],
    "oclif": {
        "bin": "universo",
        "commands": "./dist/commands"
    },
    "scripts": {
        "build": "tsc",
        "lint": "eslint --ext .ts src/",
        "test": "node ../../../tools/testing/backend/run-jest.cjs --config ./jest.config.js",
        "start": "run-script-os",
        "clean": "rimraf dist",
        "nuke": "rimraf dist node_modules .turbo",
        "start:windows": "cd bin && run start",
        "start:default": "cd bin && ./run start",
        "dev": "nodemon",
        "postpack": "shx rm -f oclif.manifest.json",
        "prepack": "pnpm build && oclif manifest && oclif readme",
        "watch": "tsc --watch",
        "version": "oclif readme && git add README.md"
    },
    "keywords": [],
    "engines": {
        "node": ">=22.6.0"
    },
    "dependencies": {
        "@google-cloud/logging-winston": "^6.0.0",
        "@oclif/core": "4.0.7",
        "@supabase/supabase-js": "^2.45.4",
        "@universo/admin-backend": "workspace:*",
        "@universo/applications-backend": "workspace:*",
        "@universo/auth-backend": "workspace:*",
        "@universo/core-frontend": "workspace:^",
        "@universo/database": "workspace:*",
        "@universo/metahubs-backend": "workspace:*",
        "@universo/migrations-platform": "workspace:*",
        "@universo/profile-backend": "workspace:*",
        "@universo/scripting-engine": "workspace:*",
        "@universo/start-backend": "workspace:*",
        "@universo/utils": "workspace:*",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "csrf": "^3.1.0",
        "dotenv": "^16.0.0",
        "express": "^4.17.3",
        "express-rate-limit": "^6.9.0",
        "express-session": "^1.18.2",
        "global-agent": "^3.0.0",
        "helmet": "^7.1.0",
        "http-status-codes": "^2.3.0",
        "passport": "^0.7.0",
        "passport-local": "^1.0.0",
        "pg": "^8.11.1",
        "reflect-metadata": "^0.1.13",
        "s3-streamlogger": "^1.11.0",
        "sanitize-html": "^2.11.0",
        "winston": "^3.9.0"
    },
    "devDependencies": {
        "@types/cookie-parser": "^1.4.8",
        "@types/cors": "^2.8.12",
        "@types/express-session": "^1.18.2",
        "@types/jest": "^29.5.12",
        "@types/passport": "^1.0.16",
        "@types/passport-local": "^1.0.38",
        "@types/sanitize-html": "^2.9.5",
        "jest": "^29.7.0",
        "nodemon": "^2.0.22",
        "oclif": "^3",
        "rimraf": "^5.0.5",
        "run-script-os": "^1.1.6",
        "shx": "^0.3.3",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.7.0",
        "tsc-watch": "^6.0.4",
        "typescript": "catalog:"
    }
}
