#!/usr/bin/env node

const { spawnSync } = require('node:child_process')

const hasNoNodeSnapshot =
	process.execArgv.includes('--no-node-snapshot') ||
	(process.env.NODE_OPTIONS || '').split(/\s+/).includes('--no-node-snapshot')

if (!hasNoNodeSnapshot) {
	const result = spawnSync(process.execPath, ['--no-node-snapshot', __filename, ...process.argv.slice(2)], {
		stdio: 'inherit',
		env: process.env
	})

	if (result.error) {
		throw result.error
	}

	process.exit(result.status ?? 1)
}

const oclif = require('@oclif/core')

oclif.run().then(require('@oclif/core/flush')).catch(require('@oclif/core/handle'))
