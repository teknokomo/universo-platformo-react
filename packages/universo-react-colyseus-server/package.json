{
    "name": "@universo-react/colyseus-server",
    "version": "0.1.0",
    "description": "Universo workspace wrapper for the Colyseus server core package",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./movement": {
            "types": "./dist/movement.d.ts",
            "import": "./dist/movement.mjs",
            "require": "./dist/movement.js"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": false,
    "scripts": {
        "clean": "rimraf dist",
        "build": "tsdown",
        "lint": "eslint --ext .ts src/",
        "test": "vitest run --config vitest.config.ts"
    },
    "license": "Omsk Open License",
    "dependencies": {
        "@colyseus/core": "catalog:"
    },
    "devDependencies": {
        "@types/node": "catalog:",
        "eslint": "catalog:",
        "rimraf": "^5.0.5",
        "tsdown": "catalog:",
        "typescript": "catalog:",
        "vitest": "catalog:"
    }
}
