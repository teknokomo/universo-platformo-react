{
    "name": "@universo/migrations-platform",
    "version": "0.1.0",
    "description": "Platform migration registry for Universo Platformo",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "clean": "rimraf dist tsconfig.tsbuildinfo",
        "build": "pnpm run clean && tsc",
        "dev": "tsc -w",
        "lint": "eslint --ext .ts src/",
        "test": "node ../../../tools/testing/backend/run-jest.cjs --config ./jest.config.js"
    },
    "keywords": [
        "universo",
        "migrations",
        "platform",
        "postgres"
    ],
    "author": "Vladimir Levadnij and Teknokomo",
    "license": "Omsk Open License",
    "dependencies": {
        "@universo/admin-backend": "workspace:*",
        "@universo/database": "workspace:*",
        "@universo/applications-backend": "workspace:*",
        "@universo/start-backend": "workspace:*",
        "@universo/migrations-catalog": "workspace:*",
        "@universo/migrations-core": "workspace:*",
        "@universo/metahubs-backend": "workspace:*",
        "@universo/profile-backend": "workspace:*",
        "@universo/schema-ddl": "workspace:*",
        "@universo/utils": "workspace:*",
        "@universo/types": "workspace:*",
        "knex": "catalog:"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/node": "catalog:",
        "eslint": "catalog:",
        "jest": "^29.7.0",
        "rimraf": "^5.0.5",
        "ts-jest": "^29.1.2",
        "typescript": "catalog:"
    }
}
