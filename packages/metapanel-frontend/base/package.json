{
    "name": "@universo/metapanel-frontend",
    "version": "0.1.0",
    "description": "Frontend module for the authenticated metapanel dashboard",
    "main": "./src/index.ts",
    "module": "./src/index.ts",
    "types": "./src/index.ts",
    "exports": {
        ".": {
            "types": "./src/index.ts",
            "import": "./src/index.ts",
            "require": "./src/index.ts"
        },
        "./i18n": {
            "types": "./dist/i18n/index.d.ts",
            "import": "./dist/i18n/index.mjs",
            "require": "./dist/i18n/index.js"
        },
        "./views": {
            "default": "./src/views/index.ts"
        },
        "./views/*": {
            "default": "./src/views/*"
        },
        "./package.json": "./package.json"
    },
    "sideEffects": [
        "dist/i18n/index.mjs",
        "dist/i18n/index.js"
    ],
    "files": ["dist", "src"],
    "scripts": {
        "clean": "rimraf dist",
        "build": "tsdown",
        "dev": "tsdown --watch",
        "lint": "eslint --ext .ts,.tsx src/",
        "test": "vitest run --config vitest.config.ts"
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/icons-material": "catalog:",
        "@mui/material": "catalog:",
        "@mui/x-charts": "catalog:",
        "@tanstack/react-query": "catalog:",
        "@universo/i18n": "workspace:*",
        "@universo/template-mui": "workspace:*",
        "@universo/types": "workspace:*",
        "axios": "catalog:",
        "i18next": "catalog:",
        "react-i18next": "catalog:"
    },
    "peerDependencies": {
        "react": ">=18",
        "react-dom": ">=18",
        "react-router-dom": ">=6"
    },
    "devDependencies": {
        "@testing-library/jest-dom": "catalog:",
        "@testing-library/react": "catalog:",
        "@types/react": "catalog:",
        "eslint": "catalog:",
        "rimraf": "^5.0.5",
        "tsdown": "catalog:",
        "vitest": "catalog:"
    }
}
