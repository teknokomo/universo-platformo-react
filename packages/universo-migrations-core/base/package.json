{
    "name": "@universo/migrations-core",
    "version": "0.1.0",
    "description": "Unified migration runtime core for Universo Platformo",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "clean": "rimraf dist tsconfig.tsbuildinfo src/*.js src/*.js.map src/*.d.ts src/*.d.ts.map",
        "build": "pnpm run clean && tsc",
        "dev": "tsc -w",
        "lint": "eslint --ext .ts src/ --ignore-pattern '**/*.d.ts'",
        "test": "node ../../../tools/testing/backend/run-jest.cjs --config ./jest.config.js"
    },
    "keywords": [
        "universo",
        "migrations",
        "backend",
        "knex",
        "postgres"
    ],
    "author": "Vladimir Levadnij and Teknokomo",
    "license": "Omsk Open License",
    "dependencies": {
        "@universo/types": "workspace:*",
        "json-stable-stringify": "catalog:",
        "knex": "catalog:",
        "uuidv7": "catalog:"
    },
    "devDependencies": {
        "@types/jest": "^29.5.12",
        "@types/node": "catalog:",
        "eslint": "catalog:",
        "jest": "^29.7.0",
        "rimraf": "^5.0.5",
        "ts-jest": "^29.1.2",
        "typescript": "catalog:"
    }
}
