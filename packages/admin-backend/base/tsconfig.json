{
    "extends": "../../../tsconfig.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": "./src",
        "baseUrl": ".",
        "paths": {
            "@universo/migrations-core": ["../../universo-migrations-core/base/dist/index.d.ts"]
        },
        "declaration": true,
        "declarationMap": true,
        "composite": true,
        "emitDecoratorMetadata": true,
        "experimentalDecorators": true,
        "types": ["node"],
        "module": "Node16",
        "moduleResolution": "node16",
        "target": "ES2020"
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist", "src/tests/**/*", "**/*.test.ts", "**/*.spec.ts"]
}
